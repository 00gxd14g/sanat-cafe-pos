# Copy to .env and adjust as needed

# SQLite (default)
DATABASE_URL=sqlite:///./pos.db

# MySQL example:
# DATABASE_URL=mysql+pymysql://user:pass@127.0.0.1:3306/posdb

CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

RUN_PRINT_WORKER=true
PRINT_POLL_SECONDS=0.8
PRINT_MAX_ATTEMPTS=3

PRINTER_KITCHEN_NAME=POS-58
PRINTER_CUSTOMER_NAME=POS-58

RECEIPT_LINE_WIDTH=32
RECEIPT_ENCODING=cp857
